{
  "name": "sales-saas",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:api": "npm run dev -w @salesapp/api",
    "dev:web": "npm run dev -w @salesapp/web",
    "build": "npm run gen:icons && npm run build -w @salesapp/web",
    "build:api": "npm run start -w @salesapp/api",
    "build:web": "npm run build -w @salesapp/web",
    "start": "npm run start -w @salesapp/api",
    "start:prod": "node scripts/start-prod.mjs",
    "preview": "npm run preview -w @salesapp/web",
    "lint": "npm run build -w @salesapp/web",
    "gen:icons": "node scripts/generate-icons.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "sync:html-theme": "node scripts/sync-html-theme.mjs",
    "sync:shared": "node scripts/port-shared.mjs && npx esbuild apps/web/src/lib/data/mappers.ts apps/web/src/lib/data/sync.ts apps/web/src/lib/api/validators.ts apps/web/src/lib/storage/types.ts apps/web/src/lib/ids.ts apps/web/src/lib/constants.ts apps/web/src/lib/format/dates.ts apps/web/src/lib/auth/permissions.ts --bundle=false --format=esm --platform=neutral --outdir=packages/shared/src --log-level=error && node scripts/fix-shared-imports.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "seed:eduardo": "node scripts/seed-eduardo-prospects.mjs",
    "db:migrate:0007": "node scripts/apply-migration-0007.mjs",
    "db:migrate:0021": "node scripts/apply-migration-0021.mjs",
    "diag:sync": "node scripts/diag-sync.mjs",
    "verify": "node scripts/verify-smoke.mjs",
    "verify:api": "npm run verify -w @salesapp/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:video-pdf": "node scripts/test-survey-calc.mjs && playwright test e2e/video-corrections.spec.js",
    "test:money-box": "node scripts/test-money-box.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
