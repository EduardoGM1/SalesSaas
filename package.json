{
  "name": "sales-saas",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run dev -w @salesapp/api",
    "dev:web": "npm run dev -w @salesapp/web",
    "dev:legacy": "next dev",
    "build": "next build",
    "build:api": "npm run start -w @salesapp/api",
    "build:web": "npm run build -w @salesapp/web",
    "start": "next start",
    "lint": "next lint",
    "gen:icons": "node scripts/generate-icons.mjs",
    "dev:clean": "node scripts/dev-clean.mjs && next dev",
    "sync:html-theme": "node scripts/sync-html-theme.mjs",
    "sync:shared": "node scripts/port-shared.mjs && npx esbuild src/lib/data/mappers.ts src/lib/data/sync.ts src/lib/api/validators.ts src/lib/storage/types.ts src/lib/ids.ts src/lib/constants.ts src/lib/format/dates.ts src/lib/auth/permissions.ts --bundle=false --format=esm --platform=neutral --outdir=packages/shared/src --log-level=error && node scripts/fix-shared-imports.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "seed:eduardo": "node scripts/seed-eduardo-prospects.mjs",
    "db:migrate:0007": "node scripts/apply-migration-0007.mjs",
    "verify": "node scripts/verify-smoke.mjs",
    "verify:api": "npm run verify -w @salesapp/api"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "serwist": "^9.5.11",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
