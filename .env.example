# ============================================================
# Sales Timeshare — Variables de entorno
# Copia este archivo a .env.local y completa los valores.
# ============================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Vite web (@salesapp/web) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Express API (@salesapp/api) ---
API_PORT=4000
# En Vercel producción: https://tu-dominio.vercel.app (recomendado para enlaces de correo)
WEB_ORIGIN=http://localhost:5173
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Vercel (producción) ---
# WEB_ORIGIN=https://sales-saas-api.vercel.app
# Vercel inyecta VERCEL_URL automáticamente; configura WEB_ORIGIN con tu dominio final (no uses el placeholder).

# Tipos de cambio (opcional; default https://api.frankfurter.dev/v1)
# FRANKFURTER_API_URL=https://api.frankfurter.dev/v1

# Solo servidor (NUNCA exponer en el cliente). Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# OneSignal (Settings → Keys & IDs en onesignal.com)
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# Mismo App ID para el cliente Vite
VITE_ONESIGNAL_APP_ID=
# Safari Web ID (Settings → Web → copiar del snippet Custom Code)
ONESIGNAL_SAFARI_WEB_ID=
VITE_ONESIGNAL_SAFARI_WEB_ID=

# Sentry (opcional; solo cliente web — fallos de vínculo OneSignal external_id)
VITE_SENTRY_DSN=

# Conexión directa para migraciones / Supabase CLI (Project Settings → Database)
DATABASE_URL=
